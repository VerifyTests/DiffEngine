<?xml version="1.0" encoding="utf-8"?>
<!--
  Code coverage settings for the Microsoft.Testing.Extensions.CodeCoverage (dotnet coverage)
  engine. Passed via the coverage settings option by coverage.ps1.

  Why this file is needed: DiffEngine and DiffEngineTray are strong name signed (key.snk).
  The dotnet coverage default configuration excludes signed assemblies by public key token, so
  without an explicit include the report comes back empty. Here we restrict instrumentation to
  the two product assemblies and include all public key tokens (overriding the default excludes).
-->
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Include>
        <ModulePath>.*DiffEngine\.dll$</ModulePath>
        <ModulePath>.*DiffEngineTray\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <PublicKeyTokens>
      <Include>
        <PublicKeyToken>.*</PublicKeyToken>
      </Include>
    </PublicKeyTokens>
    <UseVerifiableInstrumentation>False</UseVerifiableInstrumentation>
    <AllowLowIntegrityProcesses>True</AllowLowIntegrityProcesses>
    <CollectFromChildProcesses>True</CollectFromChildProcesses>
  </CodeCoverage>
</Configuration>
